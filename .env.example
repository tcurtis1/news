# Yoyosup News — environment template
# Copy to .env and fill in secrets:
#   cp .env.example .env
#
# .env is gitignored. deploy.sh will sync .env to the basement host when present.

# Public site URL (used in links / health)
PUBLIC_BASE=https://news.yoyosup.com

# Data dir inside Docker (leave as /data in compose)
CACHE_DIR=/data

# ── OpenAI Moderations (recommended for comment safety) ──────────────
# Get a key: https://platform.openai.com/api-keys
# Moderations API is typically free; you still need a Platform account.
# Paste your key after the = with no quotes:
OPENAI_API_KEY=

# Optional model override (default is fine)
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Score 0–1: hold comment for review at/above this (violence/sexual/hate, etc.)
MOD_HOLD_THRESHOLD=0.65

# ── Admin moderation queue ───────────────────────────────────────────
# Visit: https://news.yoyosup.com/admin/mod?token=YOUR_TOKEN
# Change this to any long random string you control.
# Shared admin key used across yoyosup tools (quote if it has ! or spaces)
MOD_ADMIN_TOKEN="your-admin-token-here"

# ── Comments ─────────────────────────────────────────────────────────
# Seconds between posts per IP
COMMENT_RATE_LIMIT_SEC=20

# ── Trends (optional) ────────────────────────────────────────────────
# Default location when ?geo= is omitted (country code or US-XX state)
# TRENDS_GEO=US
# TRENDS_CACHE_TTL=93600
# PULSE_CACHE_TTL=1800
